{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@analytic-pulse/shared": ["../../packages/shared/src"],
      "@analytic-pulse/ui": ["../../packages/ui/src"],
      "@analytic-pulse/ui/*": ["../../packages/ui/src/*"],
      "@analytic-pulse/rum": ["../../packages/rum/src"]
    }
  },
  "include": ["src"]
}
