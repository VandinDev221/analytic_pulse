# ─── Produção (Render) ────────────────────────────────────────

NODE_ENV=production

# Connection string do Postgres (Render existente ou Neon)
# Cole a mesma URL em DATABASE_URL e POSTGRES_URL
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
POSTGRES_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

JWT_SECRET=change-me-long-random-string
CRON_SECRET=change-me-cron-secret

# CORS (URLs do frontend, separadas por vírgula)
CORS_ORIGINS=https://analytic-pulse.vercel.app,https://analytic-pulse-web.onrender.com

# Telegram Bot (comandos /start, /status, etc.)
TELEGRAM_BOT_TOKEN=seu-token-do-botfather
TELEGRAM_WEBHOOK_SECRET=string-aleatoria-opcional
API_PUBLIC_URL=https://analytic-pulse-api.onrender.com

# Verificação por e-mail (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Analytic Pulse <noreply@seudominio.com>

# Login com Google (OAuth Client ID — tipo "Web application")
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
