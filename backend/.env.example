# ─── Produção (Render) ────────────────────────────────────────

NODE_ENV=production

# Connection string do Postgres (Render existente ou Neon)
# Cole a mesma URL em DATABASE_URL e POSTGRES_URL
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
POSTGRES_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

JWT_SECRET=change-me-long-random-string
CRON_SECRET=change-me-cron-secret

FRONTEND_URL=https://analytic-pulse-web.onrender.com
