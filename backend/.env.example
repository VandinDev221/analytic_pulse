# ─── Produção (Render) ────────────────────────────────────────
# Configure no dashboard: Render → analytic-pulse-api → Environment

NODE_ENV=production
PORT=10000

# Injetado automaticamente pelo render.yaml a partir do Postgres
POSTGRES_URL=postgresql://user:pass@host/analytic_pulse
DATABASE_URL=postgresql://user:pass@host/analytic_pulse

# Gerados automaticamente pelo Render (ou defina manualmente)
JWT_SECRET=change-me-long-random-string
CRON_SECRET=change-me-cron-secret

# URL pública do frontend (injetada pelo render.yaml)
FRONTEND_URL=https://analytic-pulse-web.onrender.com
